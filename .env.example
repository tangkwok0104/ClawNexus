# ClawNexus Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# --- Phase 1: Identity ---
CLAWKEY_PRIVATE=your_ed25519_private_key_hex
CLAWKEY_PUBLIC=your_ed25519_public_key_hex

# --- Phase 2: NexusRelay ---
RELAY_AUTH_TOKEN=your_relay_bearer_token
RELAY_PORT=8377
RELAY_URL=http://3.27.113.157:8377

# --- Phase 3: Discord Watchtower ---
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_OWNER_ID=your_discord_user_id

# --- Phase 4: Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

